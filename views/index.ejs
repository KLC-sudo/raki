<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <% if (typeof visitorId !== 'undefined' && visitorId) { %>
    <meta name="visitor-id" content="<%= visitorId %>">
    <% } %>
    <title>RAKI Coffee Co. — Meraki</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="stylesheet" href="/css/tailwind.css">
    <style>
        :root {
            --theme-bark-700: <%= settings.color_primary %>;
            --theme-bark-600: <%= settings.color_text %>;
            --theme-bark-400: <%= settings.color_border %>;
            --theme-sand: <%= settings.color_accent %>;
            --theme-cream: <%= settings.color_bg %>;
            --theme-color-text-muted: <%= settings.color_text_muted %>;
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js"></script>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-cream text-bark-700 antialiased overflow-x-hidden">

    <!-- NAVIGATION -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-cream border-b-2 border-bark-700">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#hero" class="flex items-center gap-3">
                <% if (settings.site_logo) { %>
                    <img src="<%= settings.site_logo %>" alt="RAKI" class="w-auto" style="height: <%= settings.logo_size || 40 %>px;">
                <% } else { %>
                    <div style="height: <%= settings.logo_size || 40 %>px; width: <%= settings.logo_size || 40 %>px;" class="bg-bark-700 rounded-md flex items-center justify-center">
                        <i data-lucide="coffee" class="w-5 h-5 text-sand"></i>
                    </div>
                <% } %>
            </a>

            <div class="hidden md:flex items-center gap-1">
                <% navigation.filter(n => !n.is_cta).forEach(function(item) { %>
                    <a href="<%= item.href %>" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-bark-600 hover:bg-bark-700 hover:text-sand rounded-md transition-colors"><%= item.label %></a>
                <% }); %>
                <% const ctaNav = navigation.find(n => n.is_cta); %>
                <% if (ctaNav) { %>
                    <a href="<%= ctaNav.href %>" class="ml-3 bg-bark-700 text-sand text-xs font-bold uppercase tracking-wider px-5 py-2.5 hover:bg-bark-800 rounded-md transition-colors border-2 border-bark-700"><%= ctaNav.label %></a>
                <% } %>
            </div>

            <button id="mobile-toggle" class="md:hidden w-10 h-10 bg-bark-700 rounded-md flex items-center justify-center">
                <i data-lucide="menu" class="w-5 h-5 text-sand"></i>
            </button>
        </div>

        <div id="mobile-menu" class="hidden md:hidden bg-bark-700 border-t-2 border-bark-800">
            <div class="px-6 py-4 flex flex-col gap-0">
                <% navigation.forEach(function(item) { %>
                    <a href="<%= item.href %>" class="mobile-link py-3 text-sm font-bold uppercase tracking-wider text-sand border-b border-bark-600"><%= item.label %></a>
                <% }); %>
                <% if (ctaNav) { %>
                    <a href="<%= ctaNav.href %>" class="mt-3 text-center bg-sand text-bark-700 text-sm font-bold uppercase tracking-wider px-6 py-3 rounded-md border-2 border-sand"><%= ctaNav.label %></a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <% if (settings.show_hero !== '0') { %>
    <section id="hero" class="pt-20 bg-bark-700 text-sand min-h-screen flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23F5F0E8&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

        <div class="max-w-7xl mx-auto px-6 w-full relative z-10 py-16">
            <div class="grid lg:grid-cols-12 gap-8 items-end">
                <div class="lg:col-span-7">
                    <div class="inline-flex items-center gap-2 border-2 border-bark-400 px-4 py-2 rounded-md mb-8">
                        <span class="w-2 h-2 bg-bark-300 rounded-full animate-pulse"></span>
                        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-bark-300"><%= settings.site_location %></span>
                    </div>

                    <h1 class="text-6xl md:text-8xl lg:text-[10rem] font-black leading-[0.85] tracking-tighter uppercase mb-6">
                        <%= settings.hero_title_line1 %><br>
                        <span class="text-bark-400"><%= settings.hero_title_line2 %></span>
                    </h1>

                    <p class="text-lg md:text-xl text-bark-300 leading-relaxed max-w-md mb-10 font-light">
                        <%= settings.hero_description %>
                    </p>

                    <div class="flex flex-wrap gap-4">
                        <a href="<%= settings.hero_cta_primary_link %>" class="inline-flex items-center gap-2 bg-sand text-bark-700 font-bold text-sm uppercase tracking-wider px-8 py-4 rounded-md border-2 border-sand hover:bg-transparent hover:text-sand transition-colors">
                            <%= settings.hero_cta_primary %>
                            <i data-lucide="arrow-down-right" class="w-4 h-4"></i>
                        </a>
                        <a href="<%= settings.hero_cta_secondary_link %>" class="inline-flex items-center gap-2 bg-transparent text-sand font-bold text-sm uppercase tracking-wider px-8 py-4 rounded-md border-2 border-bark-400 hover:border-sand transition-colors">
                            <%= settings.hero_cta_secondary %>
                        </a>
                    </div>
                </div>

                <div class="lg:col-span-5 hidden lg:block">
                    <div class="border-2 border-bark-400 rounded-lg p-6">
                        <div class="grid grid-cols-2 gap-6">
                            <% heroStats.forEach(function(stat, i) { %>
                                <div class="<%= i < 2 ? 'border-b-2 border-bark-400 pb-4' : '' %>">
                                    <div class="text-5xl font-black text-sand leading-none"><%= stat.value %></div>
                                    <div class="text-[10px] font-mono font-bold uppercase tracking-widest text-bark-400 mt-2"><%= stat.label %></div>
                                </div>
                            <% }); %>
                        </div>
                    </div>

                    <div class="mt-4 border-2 border-bark-400 rounded-lg p-4 flex items-center gap-4">
                        <div class="w-10 h-10 bg-bark-400 rounded-md flex items-center justify-center flex-shrink-0">
                            <i data-lucide="coffee" class="w-5 h-5 text-bark-700"></i>
                        </div>
                        <div>
                            <div class="text-xs font-black uppercase tracking-wider text-sand">Meraki Coffee</div>
                            <div class="text-[10px] font-mono text-bark-400">Consultancy · Green Beans · Roasted Beans</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="border-t-2 border-bark-400 mt-12 overflow-hidden">
            <div class="marquee-track flex items-center whitespace-nowrap py-3">
                <% var marqueeItems = (settings.marquee_items || '').split(','); %>
                <% marqueeItems.concat(marqueeItems).forEach(function(item, i) { %>
                    <% if (i > 0) { %><span class="text-bark-500 mx-2">✦</span><% } %>
                    <span class="text-[11px] font-mono font-bold uppercase tracking-[0.3em] text-bark-400 mx-8"><%= item.trim() %></span>
                <% }); %>
            </div>
        </div>

        <% if (heroImages.length > 0) { %>
        <div class="border-t-2 border-bark-400 overflow-hidden">
            <div class="flex gap-0 animate-hero-scroll">
                <% heroImages.concat(heroImages).forEach(function(img) { %>
                    <div class="flex-shrink-0 w-[400px] h-[200px] border-r-2 border-bark-400 overflow-hidden">
                        <img src="<%= img %>" alt="RAKI" class="w-full h-full object-cover opacity-60 hover:opacity-100 transition-opacity duration-300">
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </section>
    <% } %>

    <!-- PRODUCTS -->
    <% if (settings.show_products !== '0') { %>
    <section id="products" class="py-20 md:py-28 bg-cream">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
                <div>
                    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_products_label %></span>
                    <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]"><%- settings.section_products_title.replace(/\n/g, '<br>') %></h2>
                </div>
                <p class="text-sm text-bark-500 max-w-sm leading-relaxed"><%= settings.section_products_description %></p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% products.forEach(function(product, i) { %>
                    <div class="card-hover bg-white border-2 border-bark-700 rounded-lg hard-shadow-sm overflow-hidden cursor-pointer" onclick="openProductModal(<%= JSON.stringify(product).replace(/"/g, '&quot;') %>)">
                        <div class="h-56 overflow-hidden border-b-2 border-bark-700">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                        </div>
                        <div class="p-5">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-[9px] font-mono font-bold uppercase tracking-widest text-bark-400 bg-bark-50 border border-bark-200 px-2 py-1 rounded"><%= product.badge %></span>
                                <span class="text-[9px] font-mono text-bark-400"><%= String(i + 1).padStart(2, '0') %></span>
                            </div>
                            <h3 class="text-xl font-black tracking-tight uppercase mb-2"><%= product.name %></h3>
                            <p class="text-sm text-bark-500 leading-relaxed"><%= product.description %></p>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- MERAKI TRAIL -->
    <% if (settings.show_trails !== '0') { %>
<section id="meraki" class="py-20 md:py-28 bg-bark-700 text-sand">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-14">
                <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_trail_label %></span>
                <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]"><%- settings.section_trail_title.replace(/\n/g, '<br>') %></h2>
                <p class="text-sm text-bark-300 max-w-lg mt-4 leading-relaxed font-mono"><%= settings.section_trail_description %></p>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                <% trails.forEach(function(trail) { %>
                    <div class="card-hover bg-cream text-bark-700 border-2 border-bark-700 rounded-lg <%= trail.is_popular ? 'hard-shadow relative md:-translate-y-4' : 'hard-shadow-sm' %>">
                        <% if (trail.is_popular) { %>
                            <div class="absolute -top-0 right-6 bg-bark-700 text-sand text-[9px] font-mono font-bold uppercase tracking-widest px-3 py-1.5 rounded-b-md">Popular</div>
                        <% } %>
                        <div class="p-6 border-b-2 border-bark-700 flex items-center justify-between">
                            <div>
                                <span class="text-[9px] font-mono font-bold uppercase tracking-widest text-bark-400">Level 0<%= trail.level %></span>
                                <h3 class="text-2xl font-black tracking-tight uppercase mt-1"><%= trail.name %></h3>
                            </div>
                            <div class="w-12 h-12 bg-bark-700 rounded-md flex items-center justify-center">
                                <i data-lucide="<%= trail.level === 1 ? 'sprout' : trail.level === 2 ? 'trees' : 'mountain-snow' %>" class="w-6 h-6 text-sand"></i>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="flex gap-3 mb-5">
                                <span class="text-[9px] font-mono font-bold uppercase tracking-wider text-bark-500 border border-bark-300 px-2 py-1 rounded"><%= trail.duration %></span>
                                <span class="text-[9px] font-mono font-bold uppercase tracking-wider <%= trail.difficulty === 'Challenging' ? 'text-red-700 border-2 border-red-700 font-black' : 'text-bark-500 border border-bark-300' %> px-2 py-1 rounded"><%= trail.difficulty %></span>
                            </div>
                            <p class="text-sm text-bark-500 leading-relaxed mb-5"><%= trail.description %></p>
                            <ul class="space-y-2 mb-6">
                                <% (Array.isArray(trail.features) ? trail.features : []).forEach(function(f) { %>
                                    <li class="flex items-center gap-2 text-sm text-bark-600">
                                        <span class="w-1.5 h-1.5 bg-bark-700 rounded-full flex-shrink-0"></span> <%= f %>
                                    </li>
                                <% }); %>
                            </ul>
                            <a href="#subscribe" class="inline-block w-full text-center bg-bark-700 text-sand font-bold text-xs uppercase tracking-wider py-3 rounded-md border-2 border-bark-700 hover:bg-transparent hover:text-bark-700 transition-colors">Book This Trail</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- OUR STORY -->
    <% if (settings.show_story !== '0') { %>
<section id="story" class="py-20 md:py-28 bg-cream">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 items-start">
                <div class="relative">
                    <div class="border-2 border-bark-700 rounded-lg hard-shadow overflow-hidden">
                        <img src="<%= settings.section_story_image %>" alt="RAKI Story" class="w-full h-[500px] object-cover">
                    </div>
                    <div class="absolute -bottom-6 -right-3 md:right-6 bg-bark-700 text-sand p-5 border-2 border-bark-700 rounded-lg hard-shadow-sand max-w-[240px]">
                        <div class="flex items-center gap-3 mb-3 border-b border-bark-500 pb-3">
                            <div class="w-8 h-8 bg-bark-400 rounded-md flex items-center justify-center flex-shrink-0">
                                <i data-lucide="coffee" class="w-4 h-4 text-bark-700"></i>
                            </div>
                            <div>
                                <div class="text-[10px] font-mono font-bold uppercase tracking-wider text-sand">Meraki Coffee</div>
                                <div class="text-[8px] font-mono text-bark-400"><%= settings.section_story_est %></div>
                            </div>
                        </div>
                        <div class="text-[10px] font-mono text-bark-300 leading-relaxed">Consultancy · Green Beans · Roasted Beans</div>
                    </div>
                </div>

                <div class="lg:pt-8">
                    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_story_label %></span>
                    <h2 class="text-4xl md:text-5xl font-black tracking-tighter uppercase leading-[0.9] mb-6"><%- settings.section_story_title.replace(/\n/g, '<br>') %></h2>
                    <div class="border-l-4 border-bark-700 pl-5 mb-6">
                        <p class="text-bark-500 leading-relaxed"><%= settings.section_story_quote %></p>
                    </div>
                    <p class="text-sm text-bark-500 leading-relaxed mb-4"><%= settings.section_story_paragraph1 %></p>
                    <p class="text-sm text-bark-500 leading-relaxed mb-8"><%= settings.section_story_paragraph2 %></p>
                    <div class="flex flex-wrap gap-3">
                        <a href="#community" class="bg-bark-700 text-sand font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-md border-2 border-bark-700 hover:bg-transparent hover:text-bark-700 transition-colors">Our Impact →</a>
                        <a href="#events" class="bg-transparent text-bark-700 font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-md border-2 border-bark-700 hover:bg-bark-700 hover:text-sand transition-colors">Events</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <% } %>

    <!-- EVENTS -->
    <% if (settings.show_events !== '0') { %>
<section id="events" class="py-20 md:py-28 bg-bark-700 text-sand">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
                <div>
                    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_events_label %></span>
                    <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]"><%- settings.section_events_title.replace(/\n/g, '<br>') %></h2>
                </div>
                <p class="text-sm text-bark-300 max-w-sm leading-relaxed"><%= settings.section_events_description %></p>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
                <% events.forEach(function(event) { %>
                    <div class="group border-2 border-bark-500 rounded-lg hover:border-sand p-5 flex items-start gap-4 cursor-pointer transition-colors">
                        <div class="flex-shrink-0 w-14 h-14 border-2 border-bark-500 rounded-md group-hover:border-sand flex flex-col items-center justify-center transition-colors">
                            <span class="text-[8px] font-mono font-bold uppercase text-bark-400 group-hover:text-sand transition-colors"><%= event.event_month %></span>
                            <span class="text-lg font-black leading-none text-sand"><%= event.event_day %></span>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-bold uppercase tracking-tight text-sand mb-1"><%= event.title %></h4>
                            <p class="text-sm text-bark-400"><%= event.description %></p>
                        </div>
                        <i data-lucide="arrow-up-right" class="w-5 h-5 text-bark-500 group-hover:text-sand transition-colors flex-shrink-0 mt-1"></i>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- PARTNER -->
    <% if (settings.show_partner !== '0') { %>
<section id="partner" class="py-20 md:py-28 bg-sand">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-14">
                <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_partner_label %></span>
                <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]"><%- settings.section_partner_title.replace(/\n/g, '<br>') %></h2>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
                <% partners.forEach(function(partner) { %>
                    <div class="card-hover bg-white border-2 border-bark-700 rounded-lg hard-shadow-sm p-6 text-center">
                        <div class="w-14 h-14 bg-bark-700 rounded-md flex items-center justify-center mx-auto mb-5">
                            <i data-lucide="<%= partner.icon %>" class="w-7 h-7 text-sand"></i>
                        </div>
                        <h3 class="text-sm font-black uppercase tracking-tight mb-2"><%= partner.name %></h3>
                        <p class="text-xs text-bark-500 leading-relaxed"><%= partner.description %></p>
                    </div>
                <% }); %>
            </div>

            <div class="text-center mt-10">
                <a href="#subscribe" class="bg-bark-700 text-sand font-bold text-xs uppercase tracking-wider px-8 py-3.5 rounded-md border-2 border-bark-700 hover:bg-transparent hover:text-bark-700 transition-colors inline-block">Become a Partner →</a>
            </div>
        </div>
    </section>
    <% } %>

    <!-- COMMUNITY IMPACT -->
    <% if (settings.show_community !== '0') { %>
<section id="community" class="py-20 md:py-28 bg-cream">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-14">
                <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_community_label %></span>
                <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9]"><%- settings.section_community_title.replace(/\n/g, '<br>') %></h2>
            </div>

            <div class="grid lg:grid-cols-3 gap-6 mb-14">
                <% programs.forEach(function(program, i) { %>
                    <div class="card-hover bg-white border-2 border-bark-700 rounded-lg hard-shadow-sm overflow-hidden">
                        <div class="h-64 overflow-hidden border-b-2 border-bark-700">
                            <img src="<%= program.image_url %>" alt="<%= program.title %>" class="w-full h-full object-cover">
                        </div>
                        <div class="p-5">
                            <div class="flex items-center gap-2 mb-3">
                                <div class="w-8 h-8 bg-bark-700 rounded-md flex items-center justify-center">
                                    <i data-lucide="<%= program.icon %>" class="w-4 h-4 text-sand"></i>
                                </div>
                                <span class="text-[9px] font-mono font-bold uppercase tracking-widest text-bark-400">Program <%= String(i + 1).padStart(2, '0') %></span>
                            </div>
                            <h3 class="text-xl font-black tracking-tight uppercase mb-2"><%= program.title %></h3>
                            <p class="text-sm text-bark-500 leading-relaxed mb-4"><%= program.description %></p>
                            <a href="#" class="text-xs font-bold uppercase tracking-wider text-bark-700 border-b-2 border-bark-700 hover:border-bark-400 hover:text-bark-400 transition-colors pb-0.5 inline-block">Learn More →</a>
                        </div>
                    </div>
                <% }); %>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% communityStats.forEach(function(stat) { %>
                    <div class="bg-bark-700 text-sand p-5 text-center border-2 border-bark-700 rounded-lg">
                        <div class="text-3xl font-black leading-none mb-1"><%= stat.value %></div>
                        <div class="text-[9px] font-mono font-bold uppercase tracking-widest text-bark-300"><%= stat.label %></div>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- SUBSCRIPTION -->
    <% if (settings.show_subscribe !== '0') { %>
<section id="subscribe" class="py-20 md:py-28 bg-bark-700 text-sand">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 items-start">
                <div>
                    <span class="text-[10px] font-mono font-bold uppercase tracking-[0.25em] text-bark-400 mb-3 block"><%= settings.section_subscribe_label %></span>
                    <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.9] mb-6"><%- settings.section_subscribe_title.replace(/\n/g, '<br>') %></h2>
                    <p class="text-sm text-bark-300 max-w-md leading-relaxed mb-10"><%= settings.section_subscribe_description %></p>

                    <div class="space-y-3">
