                        <button type="submit" class="w-full bg-bark-700 text-sand font-bold text-sm uppercase tracking-wider py-4 rounded-md border-2 border-bark-700 hover:bg-transparent hover:text-bark-700 transition-colors flex items-center justify-center gap-2">
